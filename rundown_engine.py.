# ---------------------------------------------------------
# HIT EVALUATION (STRAIGHT / BOX / MISS)
# ---------------------------------------------------------

def is_box(pred: str, actual: str) -> bool:
    return sorted(pred) == sorted(actual)

def evaluate_rundowns(draws: DrawList) -> List[Dict[str, str]]:
    """
    For each draw, run all rundowns and compare their outputs
    to the NEXT real draw. Returns a list of hit records.
    """
    records: List[Dict[str, str]] = []

    for i in range(len(draws) - 1):
        current = draws[i]
        next_draw = draws[i + 1]["draw"]

        for name, func in RUNDOWNS.items():
            preds = func(current["draw"])
            hit_type = "miss"

            for p in preds:
                if p == next_draw:
                    hit_type = "straight"
                    break
                elif is_box(p, next_draw) and hit_type != "straight":
                    hit_type = "box"

            records.append({
                "state": current["state"],
                "game": current["game"],
                "date": current["date"],
                "rundown": name,
                "current_draw": current["draw"],
                "next_draw": next_draw,
                "hit_type": hit_type,
            })

    return records

# ---------------------------------------------------------
# RUNDOWN STRENGTH INDEX
# ---------------------------------------------------------

def build_strength_index(records: List[Dict[str, str]]) -> Dict[str, Dict[str, int]]:
    """
    Aggregates straight/box/miss counts per rundown.
    """
    index: Dict[str, Dict[str, int]] = defaultdict(lambda: {
        "straight": 0,
        "box": 0,
        "miss": 0,
    })

    for rec in records:
        r = rec["rundown"]
        index[r][rec["hit_type"]] += 1

    return index

def print_strength_index(index: Dict[str, Dict[str, int]]) -> None:
    """
    Simple console output — replace with JSON/API response if needed.
    """
    for r, stats in index.items():
        print(
            f"{r}: STRAIGHT={stats['straight']} | "
            f"BOX={stats['box']} | MISS={stats['miss']}"
        )

