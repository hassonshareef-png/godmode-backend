# ---------------------------------------------------------
# HELPERS
# ---------------------------------------------------------

def is_box(pred: str, actual: str) -> bool:
    return sorted(pred) == sorted(actual)

def detect_game_type(draw: str) -> str:
    """
    Auto-detect game type by draw length.
    3 digits -> PICK3
    4 digits -> PICK4
    """
    if len(draw) == 3:
        return "PICK3"
    elif len(draw) == 4:
        return "PICK4"
    return "UNKNOWN"

def get_rundown_set(game_type: str) -> Dict[str, RundownFunc]:
    if game_type == "PICK3":
        return PICK3_RUNDOWNS
    elif game_type == "PICK4":
        return PICK4_RUNDOWNS
    return {}

# ---------------------------------------------------------
# UNIFIED HIT EVALUATION
# ---------------------------------------------------------

def evaluate_rundowns(draws: DrawList) -> List[Dict[str, str]]:
    """
    For each draw, run all rundowns for the detected game type
    and compare their outputs to the NEXT real draw.
    Returns a list of hit records.
    """
    records: List[Dict[str, str]] = []

    for i in range(len(draws) - 1):
        current = draws[i]
        next_draw = draws[i + 1]["draw"]

        game_type = detect_game_type(current["draw"])
        rundowns = get_rundown_set(game_type)

        for name, func in rundowns.items():
            preds = func(current["draw"])
            hit_type = "miss"

            for p in preds:
                if p == next_draw:
                    hit_type = "straight"
                    break
                elif is_box(p, next_draw) and hit_type != "straight":
                    hit_type = "box"

            records.append({
                "state": current["state"],
                "game": game_type,
                "date": current["date"],
                "rundown": name,
                "current_draw": current["draw"],
                "next_draw": next_draw,
                "hit_type": hit_type,
            })

    return records

# ---------------------------------------------------------
# STRENGTH INDEX (GAME-SPECIFIC)
# ---------------------------------------------------------

def build_strength_index(records: List[Dict[str, str]], game_type: str) -> Dict[str, Dict[str, int]]:
    """
    Aggregates straight/box/miss counts per rundown for a specific game type.
    """
    index: Dict[str, Dict[str, int]] = defaultdict(lambda: {
        "straight": 0,
        "box": 0,
        "miss": 0,
    })

    for rec in records:
        if rec["game"] != game_type:
            continue
        r = rec["rundown"]
        index[r][rec["hit_type"]] += 1

    return index

# ---------------------------------------------------------
# AUTO-SELECT RUNDOWN (UNIFIED)
# ---------------------------------------------------------

def auto_select_rundown(draws: DrawList) -> Dict[str, str]:
    """
    Auto-select the rundown that hits straight for the most recent draw.
    Uses the previous draw as base, latest draw as target.
    Auto-detects Pick 3 vs Pick 4.
    """
    if len(draws) < 2:
        return {"error": "Not enough draw data"}

    last = draws[-2]
    current = draws[-1]

    target = current["draw"]
    base = last["draw"]

    game_type = detect_game_type(base)
    rundowns = get_rundown_set(game_type)

    for name, func in rundowns.items():
        preds = func(base)
        for p in preds:
            if p == target:
                return {
                    "rundown": name,
                    "hit": p,
                    "date": current["date"],
                    "state": current["state"],
                    "game": game_type,
                }

    return {
        "rundown": "none",
        "hit": "none",
        "date": current["date"],
        "state": current["state"],
        "game": game_type,
    }

# ---------------------------------------------------------
# NEXT PREDICTION (UNIFIED)
# ---------------------------------------------------------

def next_prediction(draws: DrawList) -> Dict[str, str]:
    """
    After auto-selecting the winning rundown,
    generate the NEXT prediction (straight candidate) for the detected game.
    """
    auto = auto_select_rundown(draws)

    if auto.get("rundown") == "none":
        return {
            "prediction": "none",
            "rundown": "none",
            "type": "none"
        }

    rd = auto["rundown"]
    latest = draws[-1]["draw"]
    game_type = detect_game_type(latest)
    rundowns = get_rundown_set(game_type)

    preds = rundowns[rd](latest)
    next_straight = preds[0]

    return {
        "prediction": next_straight,
        "rundown": rd,
        "type": "straight_candidate",
        "game": game_type,
        "state": draws[-1]["state"],
        "date": draws[-1]["date"],
    }

