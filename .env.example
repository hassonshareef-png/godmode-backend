# Required application secrets
SECRET_KEY=replace-with-a-long-random-value
ADMIN_KEY=replace-with-a-separate-long-random-value
DIRECTOR_PIN=replace-with-a-private-pin

# Persistent production database (Render Postgres recommended)
DATABASE_URL=postgresql://user:password@host:5432/database

# Frontend origins allowed to call the API, comma-separated
CORS_ORIGINS=https://godmode-frontend-l.onrender.com

# Stripe Payment Links and signed webhook endpoint
STRIPE_PAYMENT_LINK_GOD=https://buy.stripe.com/replace_me
STRIPE_PAYMENT_LINK_UNIVERSE=https://buy.stripe.com/replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Optional token lifetime overrides
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# Development/testing only; never enable in production
EXPOSE_RESET_TOKEN=false
